# Supabase client configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase server-side API routes
# Required by /api/jan-product, /api/kaitorix and scheduled push jobs.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Kaitorix product / buyback lookup
# Optional. Comma-separated tokens; the product-name lookup uses the first token.
KAITORIX_API_TOKENS=your_token1,your_token2
NEXT_PUBLIC_KAITORIX_RATE_LIMIT_MODE=ultra-safe

# Coupon OCR
# Optional unless you use coupon image OCR.
ANTHROPIC_API_KEY=sk-ant-...

# Web Push notifications
# Required for browser push subscription and /api/push/* send endpoints.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Optional LINE reminder fallback for /api/push/daily
LINE_REMINDER_URL=https://your-line-reminder-endpoint
